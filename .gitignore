# 依存・ビルド成果物
node_modules/
dist/

# ハーネスの状態ファイル（シークレットや個別環境の情報を含むためコミットしない）
.saas-launch-state.json

# 対象アプリの実設定（テンプレートは *.example.json のみコミット）
harness.config.json

# 環境変数
.env
.env.*
!.env.example

# ローカルのシークレット・CLI 資格情報（対象アプリ側でも誤コミットしないこと）
.dev.vars
.dev.vars.*
.wrangler/
.vercel/

# OS/エディタ
.DS_Store
*.log
