{
  "name": "saas-launch-harness",
  "version": "0.1.0",
  "description": "非エンジニアがコマンド1つで SaaS を Cloudflare(バックエンド) + Vercel(フロント) にデプロイできるローンチ・ハーネス。AIエージェントが設定をヒアリングし、進捗を可視化し、失敗しても続きから再開できる。",
  "type": "module",
  "bin": {
    "saas-launch": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "docs",
    "templates",
    "harness.config.example.json",
    "AGENTS.md",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "setup": "tsx src/index.ts setup",
    "doctor": "tsx src/index.ts doctor",
    "status": "tsx src/index.ts status",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "vercel",
    "deploy",
    "harness",
    "saas",
    "cli",
    "claude-code"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "execa": "^9.5.1",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
